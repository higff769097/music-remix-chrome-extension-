{
  "manifest_version": 3,
  "name": "YouTube Music Remixer",
  "description": "custom your favourite segment and feel the vibe.",
  "version": "1.0",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://music.youtube.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://music.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
